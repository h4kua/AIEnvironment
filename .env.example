# Flood AI environment template
# Copy to .env and fill in real values. Never commit .env.

# [DB] PostgreSQL — required by run_migration.py
DB_HOST=localhost
DB_PORT=5432
DB_NAME=flood_ai
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_CONNECT_TIMEOUT=10
DB_APP_NAME=flood-ai-pipeline
DB_POOL_MIN=2
DB_POOL_MAX=20

# [API]
FLOOD_API_KEYS=demo123
FLOOD_API_RATE_LIMIT=30
FLOOD_REQUEST_BUDGET_S=15
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ORIGINS=http://localhost:8000
FLOOD_LOAD_DOTENV=1
ENVIRONMENT=development

# [AGENTS]
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
ANTHROPIC_TIMEOUT_S=20
ANTHROPIC_MAX_RETRIES=3
ANTHROPIC_MAX_TOKENS=1024
GOOGLE_MAPS_API_KEY=
OPENWEATHER_API_KEY=
BNPB_DEFAULT_VINTAGE_DAYS=30
FLOOD_ALLOW_RUNTIME_SCRAPE=0
FLOOD_STAGE_WORKERS=4

# [TIMEOUTS]
TIMEOUT_PERCEPTION_S=5
TIMEOUT_REASONING_S=8
TIMEOUT_EVALUATION_S=5
TIMEOUT_ACTION_S=3
TIMEOUT_ROUTING_S=10

# [OBSERVABILITY]
LOG_LEVEL=INFO
MONITORING_ENABLED=false
MONITORING_URL=http://localhost:8080
SLACK_WEBHOOK_URL=
SLACK_CHANNEL=#flood-alerts

# [PIPELINE]
JAKARTA_LAT=-6.2088
JAKARTA_LON=106.8456
MODEL_PATH=./artifacts/models/flood_model_jakarta.pkl
SCALER_PATH=./artifacts/models/scaler_jakarta.pkl
THRESHOLD_PATH=./artifacts/configurations/optimal_threshold.json
N_WORKERS=4
CACHE_ENABLED=true
CACHE_TTL=3600
BATCH_SIZE=32
